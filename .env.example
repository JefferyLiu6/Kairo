# ── LLM provider for /orchestrator/stream and live fallback ───────────────────
# Anthropic
ANTHROPIC_API_KEY=
# MODEL=claude-haiku-4-5-20251001

# Or use OpenAI
# OPENAI_API_KEY=
# MODEL=gpt-4o-mini

# Or use local Ollama
# OLLAMA=1
# OLLAMA_BASE_URL=http://127.0.0.1:11434
# MODEL=llama3.2

# Optional: use a cheaper/faster model for delegated PM calls.
# PM_MODEL=gpt-4o-mini

# ── Server ────────────────────────────────────────────────────────────────────
AGENT_PORT=8766
DATA_DIR=./data
# VAULT_DIR=./vault

# ── Optional: Google Calendar sync ───────────────────────────────────────────
# GOOGLE_CALENDAR_CLIENT_ID=...
# GOOGLE_CALENDAR_CLIENT_SECRET=...
# GOOGLE_CALENDAR_REDIRECT_URI=http://localhost:8766/personal-manager/google-calendar/callback

# ── Auth / cookies ───────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SESSION_SECRET=
# Same-origin local dev can use strict. Cross-origin production should use none.
COOKIE_SAMESITE=strict
# Set false only for local HTTP development.
COOKIE_SECURE=false

# ── CORS / rate limits ───────────────────────────────────────────────────────
# Local Vite dev normally uses the proxy, so CORS can stay unset.
# CORS_ORIGINS=http://localhost:5173
RATE_LIMIT_RPM=60

# ── Legacy local-dev routes ──────────────────────────────────────────────────
# Keep disabled for public deployments. If enabled, also set GATEWAY_TOKEN.
ENABLE_DEMO_WEB_ROUTES=0
GATEWAY_TOKEN=
