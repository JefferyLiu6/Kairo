# ── Backend ───────────────────────────────────────────────────────────────────
# Public URL of the backend (no trailing slash). Used to derive Google OAuth
# redirect URI when GOOGLE_CALENDAR_REDIRECT_URI is not set.
PUBLIC_URL=https://api.example.com

# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SESSION_SECRET=change-me-to-a-random-32-byte-hex-secret

# Cookie policy for cross-origin production frontend/backend deployments.
# Use COOKIE_SAMESITE=strict instead if frontend and backend are same-origin.
COOKIE_SECURE=true
COOKIE_SAMESITE=none

# Required for cross-origin cookie auth. Use the exact frontend origin.
CORS_ORIGINS=https://kairo-hazel.vercel.app

# Keep legacy workspace/terminal demo routes disabled in public deployments.
ENABLE_DEMO_WEB_ROUTES=0

# Optional: only used if ENABLE_DEMO_WEB_ROUTES=1 for a private/dev deployment.
GATEWAY_TOKEN=

# Abuse controls
TRUST_PROXY_HEADERS=true
RATE_LIMIT_RPM=60
PM_DEMO_RATE_LIMIT_RPM=20
PM_DEMO_RATE_LIMIT_DAILY=100
AUTH_SIGNUP_RATE_LIMIT_RPM=5
AUTH_SIGNUP_RATE_LIMIT_HOURLY=20
AUTH_SIGNUP_RATE_LIMIT_DAILY=50
AUTH_LOGIN_RATE_LIMIT_RPM=10
AUTH_LOGIN_RATE_LIMIT_HOURLY=50
AUTH_LOGIN_EMAIL_LIMIT_15M=5
AUTH_CSRF_RATE_LIMIT_RPM=30
AUTH_DEMO_RATE_LIMIT_RPM=2
AUTH_DEMO_RATE_LIMIT_HOURLY=10
AUTH_DEMO_RATE_LIMIT_DAILY=25

# ── LLM provider (pick one) ───────────────────────────────────────────────────
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Model overrides (optional; sensible defaults used if omitted)
# MODEL=claude-haiku-4-5-20251001
# PM_MODEL=gpt-4o-mini

# ── Google Calendar (optional) ────────────────────────────────────────────────
GOOGLE_CALENDAR_CLIENT_ID=
GOOGLE_CALENDAR_CLIENT_SECRET=
# Override if auto-derive from PUBLIC_URL is not right:
# GOOGLE_CALENDAR_REDIRECT_URI=https://api.example.com/personal-manager/google-calendar/callback

# ── Frontend (build-time, set before running: pnpm build) ─────────────────────
VITE_API_BASE=https://api.example.com
