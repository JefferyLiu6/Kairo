# ── Backend ───────────────────────────────────────────────────────────────────
# Public URL of the backend (no trailing slash). Used to auto-derive OAuth redirect URI.
PUBLIC_URL=https://api.example.com

# Strong random secret — backend routes require this as Bearer token.
# For a public portfolio demo, this is only a demo gate if also embedded below
# as VITE_GATEWAY_TOKEN; do not rely on it for real user data.
GATEWAY_TOKEN=change-me-to-a-strong-random-secret

# Comma-separated frontend origin(s) for CORS
CORS_ORIGINS=https://example.com

# ── LLM provider (pick one) ───────────────────────────────────────────────────
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Model overrides (optional — sensible defaults used if omitted)
# MODEL=claude-3-5-haiku-20241022
# PM_MODEL=gpt-4o-mini

# ── Google Calendar (optional) ────────────────────────────────────────────────
GOOGLE_CALENDAR_CLIENT_ID=
GOOGLE_CALENDAR_CLIENT_SECRET=
# Override if auto-derive from PUBLIC_URL isn't right:
# GOOGLE_CALENDAR_REDIRECT_URI=https://api.example.com/personal-manager/google-calendar/callback

# ── Demo limits ───────────────────────────────────────────────────────────────
DEMO_SESSION_LIMIT=6
RATE_LIMIT_RPM=60

# ── Frontend (build-time, set before running: pnpm build) ─────────────────────
VITE_API_BASE=https://api.example.com
VITE_GATEWAY_TOKEN=change-me-to-a-strong-random-secret
