AGENT_PORT=8766

# LangSmith tracing (https://smith.langchain.com)
# Set LANGCHAIN_API_KEY to enable — LangChain/LangGraph picks it up automatically.
# Traces appear under the project name in LangSmith UI.
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=my-assistant
# LANGCHAIN_TRACING_V2=true   # auto-set when API key is present
# LANGSMITH_HIDE_INPUTS=true  # redact sensitive tool inputs from traces
# Log tool calls / steps from master & personal_manager to the backend (assistant.agent). Set 0 to disable.
AGENT_TRACE=1
DATA_DIR=./data
VAULT_DIR=../vault
WORKSPACE_DIR=../workspace

# Provider configuration (same rules as history_version / TS gateway)
#
# Ollama Cloud — set key + optional MODEL (default gpt-oss:120b); base URL defaults to https://ollama.com
OLLAMA_API_KEY=
# Optional override when using Cloud (defaults to https://ollama.com)
# OLLAMA_BASE_URL=https://ollama.com
#
# Local Ollama — set OLLAMA=1 and optionally OLLAMA_BASE_URL (default http://127.0.0.1:11434)
# OLLAMA=1
# OLLAMA_BASE_URL=http://127.0.0.1:11434
#
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
ANTHROPIC_API_KEY=
MODEL=gpt-4o-mini

# Auth / session cookies
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SESSION_SECRET=
# Cookie policy — use "strict" for same-origin dev, "none" for cross-origin prod
COOKIE_SAMESITE=strict
# Set to false only for local HTTP development (never in production)
COOKIE_SECURE=true

# CORS — only needed when the frontend is served from a different origin than the backend.
# Local dev uses the Vite proxy (same-origin), so this can stay unset.
# Production (VITE_API_BASE pointing at a separate API domain): set to your exact frontend origin.
# IMPORTANT: credentials (cookies) are only sent cross-origin when this is an explicit list.
#            Leaving it unset or "*" disables credentialed cross-origin (safe default).
# CORS_ORIGINS=https://yourapp.example.com

# Legacy: no longer used when user accounts are enabled.
# Keep set if you want the old single-token gateway fallback.
GATEWAY_TOKEN=
